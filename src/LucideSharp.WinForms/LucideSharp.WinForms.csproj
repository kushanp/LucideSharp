<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0-windows;net6.0-windows;net48</TargetFrameworks>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>LucideSharp.WinForms</RootNamespace>
    <AssemblyName>LucideSharp.WinForms</AssemblyName>
    <LangVersion>latest</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>

    <!-- NuGet package metadata -->
    <PackageId>LucideSharp</PackageId>
    <Version>1.0.0</Version>
    <Authors>LucideSharp Contributors</Authors>
    <Company>LucideSharp</Company>
    <Product>LucideSharp</Product>
    <Description>Beautiful Lucide SVG icons for Windows Forms with high-quality SkiaSharp rendering, designer support, and smart bitmap caching.</Description>
    <PackageTags>winforms;svg;icons;lucide;lucidesharp;skiasharp</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/lucidesharp/lucidesharp</PackageProjectUrl>
    <RepositoryUrl>https://github.com/lucidesharp/lucidesharp</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageIcon>icon.png</PackageIcon>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Svg.Skia" Version="3.0.0" />
    <PackageReference Include="Svg" Version="3.4.7" Aliases="ClassicSvg" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
    <None Include="..\..\assets\icon.png" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>